# ZK Payroll SDK — Example Configuration
#
# Copy this file to examples/.env and fill in the values for your environment.
# When these variables are absent the examples run in demo mode (no live network).
#
# Usage:
#   cp examples/.env.example examples/.env
#   # edit examples/.env with your values
#   source examples/.env && npx tsx examples/employee-onboarding.ts

# ── Network ──────────────────────────────────────────────────────────────────
# Soroban RPC endpoint.
# Testnet:  https://soroban-testnet.stellar.org
# Mainnet:  https://mainnet.stellar.validationcloud.io/v1/<api-key>
NETWORK_URL=https://soroban-testnet.stellar.org

# ── Contract ──────────────────────────────────────────────────────────────────
# The strkey (C...) of the deployed ZK Payroll Soroban contract.
CONTRACT_ID=

# ── Keypairs ──────────────────────────────────────────────────────────────────
# Secret key of the employer/admin account that signs payroll transactions.
# Generate a test keypair: https://laboratory.stellar.org/#account-creator?network=testnet
EMPLOYER_SECRET=
ADMIN_SECRET=

# ── Employee (onboarding example) ─────────────────────────────────────────────
# Public key (G...) of the employee being onboarded.
EMPLOYEE_ADDRESS=

# ── Circuit artifacts (payroll-execution example) ─────────────────────────────
# Public URLs to the compiled Circom circuit files.
# Contact the ZK Payroll team or compile the circuit yourself — see docs/ZK_PROOF_GENERATION.md.
WASM_URL=
ZKEY_URL=
